          "600 г борошна",
          "1 ст.л соняшникової олії"
        ],
        "steps": [
          {
            "number": 1,
            "text": "Поставити опару: тепле молоко + дріжджі + 1 ст.л цукру + 200 г борошна (просіяти)."
          },
          { "number": 2, "text": "Поставити у тепле місце." },
          {
            "number": 3,
            "text": "Яйця (один жовток залишити для змащування) + сіль + 2 ст.л цукру + розтоплене масло — перемішати."
          },
          { "number": 4, "text": "Опара підійде — замішувати тісто." },
          {
            "number": 5,
            "text": "В опару додати здобу, перемішати + 400 г борошна. Наприкінці 1 ст.л олії."
          },
          {
            "number": 6,
            "text": "Залишити на 15 хв, обім’яти, ще 15 хв — формувати."
          },
          { "number": 7, "text": "Випікати 20–25 хв при 200–220°C." }
        ]
      },
