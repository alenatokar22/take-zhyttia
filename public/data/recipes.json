  "sweetBaking": {
    "id": "sweet-baking",
    "title": "Випічка солодка",
    "recipes": [
      {
        "id": "sweet-baking-01",
        "title": "Шарлотка з яблуками",
        "country": "Україна",
        "servings": 8,
        "timeMinutes": 60,
        "heroImage": "/images/Sharlotka_z_yablukamy.png",
        "youtubeUrl": "https://www.youtube.com/watch?v=LpTSQHUDiNo",
        "tags": [],
        "ingredients": [
          "4 яблука",
          "1 ч.л кориці",
          "4 яйця",
          "200 г цукру",
          "1 ч.л ванільного цукру",
          "160 г борошна",
          "1 ч.л розпушувача",
          "10 г олії",
          "20 г цукрової пудри"
        ],
        "steps": [
          {
            "number": 1,
            "text": "Просіяти борошно з розпушувачем. Яблука помити, очистити."
          },
          {
            "number": 2,
            "text": "Збити яйця з цукром і ванільним цукром до пишної піни (5–6 хв)."
          },
          {
            "number": 3,
            "text": "Акуратно ввести борошно, перемішати лопаткою."
          },
          {
            "number": 4,
            "text": "Яблука нарізати тонкими скибочками, посипати корицею."
          },
          {
            "number": 5,
            "text": "Форму змастити. Половина тіста → яблука → друга половина тіста → яблука."
          },
          {
            "number": 6,
            "text": "Випікати 30–40 хв при 180°C. Охолодити і посипати пудрою."
          }
        ]
      },
      {
        "id": "sweet-baking-02",
        "title": "Штолен",
        "country": "Німеччина",
        "servings": 4,
        "timeMinutes": null,
        "heroImage": "/images/Sttolen.png",
        "youtubeUrl": "https://www.youtube.com/watch?v=ryP2HStD-fo&list=LL&index=17&t=6s",
        "tags": [],
        "ingredients": [
          "250 г журавлина",
          "250 г родзинки",
          "150 г цукати",
          "150 мл ром / міцний чай / апельсиновий сік",
          "200 г фундук / мигдаль",
          "цедра одного апельсин",

          "200 г масло вершкове 82%",
          "100 г цукор",
          "400 г цукрова пудра",

          "30 г дріжджі",
          "400 мл молоко",
          "200 г цукор",
          "1 кг борошно",
          "150 г подрібнений мигдаль",
          "10 г сіль",
          "1 ч.л. суміш спецій",
          "400 г масло вершкове 82%"
        ],
        "steps": [
          {
            "number": 1,
            "text": "Сухофрукти залити апельсиновий соком за 12 годин до того, як готувати штолен."
          },
          {
            "number": 2,
            "text": "Дріжджі + молоко (30°C) + цукор - поєднати між собою."
          },
          {
            "number": 3,
            "text": "Мигдаль перебити, щоб була крошка."
          },
          {
            "number": 4,
            "text": "Добавити борошно + перебитий мигдаль + сіль +  суміш спецій - замішати тісто."
          },
          {
            "number": 5,
            "text": "Добавити поступово м’яке вершкове масло - замішувати 10 хвилин."
          },
          {
            "number": 6,
            "text": "Розрівняти тісто в тонкий пласт + добавити цедру апельсина + замочени сухофрукти (якщо залишилась редина, треба вилити, в тісто не потрібно добавляти) + фундук трішки подрібнити. Добре перемішати, обережно, щоб цукати не стали кашою. "
          },
          {
            "number": 7,
            "text": "Готове тісто перекласти в миску та накрити плівкою, залишити на 2 години."
          },
          {
            "number": 8,
            "text": "Розділити тісто на чотири штолена десь по 800 г."
          },
          {
            "number": 9,
            "text": "Формувати штолен, розрівняти (родзинки зверху прибрати, щоб не засмажились у духовці) закручувати з однієї сторони більше і з іншою сторони меньше."
          },
          {
            "number": 10,
            "text": "На деко, накрити плівкою на 40 хвилин."
          },
          {
            "number": 11,
            "text": "Випікати 45 хв. при 175 °С режим конвекція, якщо випікати декілько противень одразу."
          },
          {
            "number": 12,
            "text": "Розтопити вершкове масло, поки гарячі штолени промазати з усіх сторін маслом + цукор дрібний + цукрова пудра."
          },
          {
            "number": 13,
            "text": "Охолодити штолени на решитці. "
          },
          {
            "number": 14,
            "text": "Після повного охолодження, якщо відсутня цукрова пудра, треба добавити. Скласти у пакети та у холодне місто, штолен дозріває від тижня до 3 місяців."
          }
        ]
      },
      {
        "id": "sweet-baking-03",
        "title": "Портокалопіта",
        "country": "Греція",
        "servings": 10,
        "timeMinutes": 90,
        "heroImage": null,
        "youtubeUrl": null,
        "tags": [],
        "ingredients": [
          "250 г тісто філо",
          "200 г йогурт грецький",
          "200 г олія соняшникова",
          "480 г цукор",
          "2 шт апельсин",
          "4 шт яйце",
          "10 г розпушувач",
          "500 мл вода",
          "1 пакетик ванілін"
        ],
        "steps": [
          {
            "number": 1,
            "text": "Вийняти листи тіста філо з упаковки, грубо порвати їх на шматочки і залишити висихати на 60 хв чи довше, щоб вони стали ламкими."
          },
          {
            "number": 2,
            "text": "Зняти цедру з апельсинів (з одного апельсина окремо покласти), вичавити сік і грубо нарізати м’якоть. Другий апельсин тонко нарізати кружальцями. У каструлі змішати воду, цукор, цедру, сік і шматочки апельсина разом зі скибочками другого апельсина. Додати пів пакетика ваніліну. Варити 10 хв, потім повністю охолодити сироп."
          },
          {
            "number": 3,
            "text": "Розігріти духовку до 170°C. У мисці змішати олію і цукор. Додати йогурт, цедру, решту ваніліну і розпушувач і перемішати. Додати яйця по одному і щоразу добре перемішати. Наприкінці додати шматочки тіста філо і ретельно перемішати."
          },
          {
            "number": 4,
            "text": "Вилити тісто у форму, вистелену пергаментом (кращє брати форму цілу). Вийняти кружальця апельсина із сиропу і викласти зверху. Випікати у розігрітій духовці 40 хв при 170°C."
          },
          {
            "number": 5,
            "text": "Вийняти пиріг з духовки і відразу залити холодним сиропом. Дати просочитися і повністю охолонути перед подачею."
          },
          {
            "number": 6,
            "text": "Подавати портокалопіту охолодженою."
          }
        ]
      },
