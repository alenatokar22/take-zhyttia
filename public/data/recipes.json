    "recipes": [
      {
        "id": "firstDishes-01",
        "title": "Рибний чаудер",
        "country": "Україна",
        "servings": 4,
        "timeMinutes": 40,
        "heroImage": "/images/Rybnyy_chauder.png",
        "youtubeUrl": "https://www.youtube.com/watch?v=I70aIGqqHVw&list=LL&index=15",
        "tags": [],
        "ingredients": [
          "400 г філе хека або іншої білої риби",
          "400 г картопля",
          "150 г броколі",
          "1 шт ріпчаста цибуля",
          "1 шт морква",
          "100 г кукурудза (заморожена чи консервована)",
          "1 л рибний або овочевий бульйон",
          "200 мл вершки 15–20%",
          "30 г вершкове масло",
          "1 шт лавровий лист",
          "1 ч.л сіль",
          "0.25 ч.л чорний мелений перець",
          "5 г зелень"
        ],
        "steps": [
          {
            "number": 1,
            "text": " Почистити ріпчасту цибулю та моркву, нарізати дрібними кубиками. Розігріти вершкове масло в каструлі, обсмажити овочі, помішуючи, до м’якості."
          },
          {
            "number": 2,
            "text": "Почистити картоплю від шкірки, нарізати кубиками та додати до обсмажених овочів."
          },
          {
            "number": 3,
            "text": "Залити овочі бульйоном, додати лавровий лист і чебрець. Довести до кипіння та варити на середньому вогні близько 10 хвилин."
          },
          {
            "number": 4,
            "text": " Додати в каструлю кукурудзу та броколі, розділену на дрібні суцвіття. Готувати ще 5 хвилин."
          },
          {
            "number": 5,
            "text": "Нарізати рибу шматочками середнього розміру, викласти у каструлю. Варити на повільному вогні 7–8 хвилин, поки риба не стане ніжною і не почне легко розділятися на волокна."
          },
          {
            "number": 6,
            "text": " Влити вершки, додати сіль і перець. Перемішати, довести суп до кипіння, після чого одразу вимкнути вогонь."
          },
          {
            "number": 7,
            "text": "Подавати рибний чаудер гарячим, посипавши свіжою зеленню. До нього чудово пасує хрусткий хліб або часникові грінки."
          }
        ]
      },
      {
        "id": "firstDishes-02",
        "title": "Турецький суп із сочевицею",
        "country": "Україна",
        "servings": 4,
        "timeMinutes": 50,
        "heroImage": "/images/...png",
        "youtubeUrl": null,
        "tags": [],
